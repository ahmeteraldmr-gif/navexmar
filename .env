APP_NAME=Navexmar
APP_ENV=production
APP_KEY=base64:7vF6F9/3mXJ9X9X9X9X9X9X9X9X9X9X9X9X9X9X9X9X=
APP_DEBUG=false
APP_URL=https://navexmar.com

# 💾 VERİTABANI BAĞLANTI AYARLARI
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=navexmar_navex
