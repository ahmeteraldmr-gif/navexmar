# 📧 MAIL (SMTP) AYARLARI (Gelecek Özellikler İçin)
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
