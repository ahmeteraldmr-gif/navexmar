MAIL_FROM_NAME="${APP_NAME}"

# 🛡️ GÜVENLİK VE OTURUM
# ------------------------------------------------------------------------------
SESSION_LIFETIME=120
CACHE_DRIVER=file

# 🌐 DİL AYARLARI
# ------------------------------------------------------------------------------
DEFAULT_LANGUAGE=tr
SUPPORTED_LANGUAGES=tr,en

